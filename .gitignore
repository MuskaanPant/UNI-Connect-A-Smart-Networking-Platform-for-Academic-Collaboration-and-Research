# Root level gitignore

# Dependencies
node_modules/

# Environment variables
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Build directories
build/
dist/

# Package manager
package-lock.json
yarn.lock
pnpm-lock.yaml

# Temporary files
*.tmp
*.temp
.cache/

# Documentation (optional - remove if you want to commit these)
# *.md